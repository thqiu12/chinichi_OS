# Postgres (本地 docker / Supabase / Neon 都行)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chinichi"

# 若不设置，AI / WeCom 会自动走 mock，不影响运行
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

WECOM_CORP_ID=""
WECOM_SECRET=""
WECOM_AGENT_ID=""

# Cron 调用用的简单 token（curl 时带）
CRON_SECRET="dev-cron-secret"

# 应用 URL（Server Actions / 跳转用）
NEXT_PUBLIC_APP_URL="http://localhost:3000"
