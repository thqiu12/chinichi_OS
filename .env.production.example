# Copy to .env on the server. NEVER commit the real .env.
#
# Required
POSTGRES_PASSWORD=change-me-strong-random-32-chars
NEXTAUTH_SECRET=change-me-openssl-rand-base64-32
CRON_SECRET=change-me-openssl-rand-base64-32

# URL the app serves on (matches your domain). Used for callbacks/links.
NEXTAUTH_URL=https://crm.example.cn
NEXT_PUBLIC_APP_URL=https://crm.example.cn

# Optional (mock-mode if empty)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

WECOM_CORP_ID=
WECOM_SECRET=
WECOM_AGENT_ID=

# If you use阿里云 RDS instead of the in-stack postgres, replace DATABASE_URL
# inside docker-compose.yml's web service (or just set it here and read it).
# DATABASE_URL=postgresql://user:pass@rds-host.aliyuncs.com:5432/chinichi?sslmode=require
